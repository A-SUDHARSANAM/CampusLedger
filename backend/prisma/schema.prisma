generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Admin
  LabIncharge
  Service
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(Admin)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
