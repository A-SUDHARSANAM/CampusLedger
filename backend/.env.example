# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=CampusLedger
APP_VERSION=1.0.0
DEBUG=false

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Direct PostgreSQL connection (Project Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:Sudha2006.A123@db.hcgpbynxmzwnvmozkjbz.supabase.co:5432/postgres

# Use the anon key for public access, or service role key for admin/server-side access
# Project Settings → API → Project API keys
SUPABASE_KEY=your-anon-or-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── OCR (optional) ────────────────────────────────────────────────────────────
# Leave blank to use local Tesseract; set to enable GPT-4 Vision (higher accuracy)
OPENAI_API_KEY=
# Path to tesseract binary — only needed on Windows if not on PATH
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8081"]
